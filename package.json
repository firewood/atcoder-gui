{
  "name": "atcoder-gui",
  "version": "1.1.4",
  "description": "Browser automation tool for AtCoder with CLI interface",
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "atcoder-gui": "dist/main.js"
  },
  "files": [
    "dist/**/*",
    "vscode-project-files/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "./build.sh",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:scenario": "vitest run src/tests/scenario.test.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "check": "tsx src/generator/checker.ts",
    "start": "tsx src/main.ts",
    "start:built": "node dist/main.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test && pnpm run lint",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/firewood/atcoder-gui.git"
  },
  "keywords": [
    "atcoder",
    "browser-automation",
    "cli",
    "competitive-programming",
    "playwright",
    "typescript"
  ],
  "author": "firewood <174658+firewood@users.noreply.github.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/firewood/atcoder-gui/issues"
  },
  "homepage": "https://github.com/firewood/atcoder-gui#readme",
  "dependencies": {
    "cheerio": "^1.2.0",
    "conf": "^15.1.0",
    "globals": "^16.5.0",
    "json5": "^2.2.3",
    "nunjucks": "^3.2.4",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/nunjucks": "^3.2.6",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "encoding-sniffer": "1.0.2"
    }
  }
}
